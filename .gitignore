*.whl

# Virtual env

venv/
.venv/
env/

# Data
data/*.json
!data/dpo_dataset.jsonl

# Logs (judge evidence only)
logs/*
!logs/summary.json
!logs/episodes.csv

# Models (avoid heavy artifacts)
models/*
