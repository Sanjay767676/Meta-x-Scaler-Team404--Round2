!outputs/*.png
!outputs/*.jpg
!outputs/*.md
!outputs/*.json

# Keep optional trend charts if generated
!outputs/*trend*.png
!outputs/tier_progression.png

# Explicitly ignore bulky nested runtime artifacts
outputs/run_artifacts/
outputs/reward_graphs/

# Notebook (keep one proof notebook)
*.ipynb
!FORGE_Training_Colab.ipynb

# Secrets
.env

