# Copy to `.env` locally OR set the same names in Hugging Face Space → Settings → Secrets.
# Never put real tokens in this file or commit them to git.

BASE_MODEL_ID=Qwen/Qwen2.5-Coder-1.5B-Instruct
HF_MODEL_ID=sanjay7676/forge-qwen-final
HF_TOKEN=

NIM_API_KEY=
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_BASE_URL=https://integrate.api.nvidia.com/v1

OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen2.5-coder-7b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Policy "model": auto | custom_hf | nim | openrouter | mock
CODE_PROVIDER_MODE=auto

ROUTER_HF_TIMEOUT_SEC=360
ROUTER_NIM_TIMEOUT_SEC=90
ROUTER_OPENROUTER_TIMEOUT_SEC=90
